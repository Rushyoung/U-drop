# U-Drop 生产环境配置示例

# --- 基础配置 ---
# 日志等级: DEBUG, INFO, WARNING, ERROR, SUCCESS
LOG_LEVEL=INFO

# --- 管理员自举 (仅在系统首次启动且数据库为空时生效) ---
# ADMIN_ACCOUNT=admin
# ADMIN_PASSWORD=your_secure_password

# --- 系统开关 ---
# 是否开放注册 (True/False)
ALLOW_REGISTRATION=True

# --- 启动配置 ---
API_HOST=0.0.0.0
API_PORT=8000

# --- 存储路径 (默认为项目根目录下的 storage) ---
# STORAGE_ROOT=/data/udrop/storage

# --- 数据库路径 (默认为项目根目录下的 udrop.db) ---
# DB_NAME=udrop.db
